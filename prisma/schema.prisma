generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Negocio {
  id            Int       @id @default(autoincrement())
  nombre        String
  email         String    @unique
  apiKey        String    @unique @default(cuid())
  adminPassword String?
  creadoEn      DateTime  @default(now())
  empleados     Empleado[]
  citas         Cita[]
}

model Empleado {
  id             Int            @id @default(autoincrement())
  negocio        Negocio        @relation(fields: [negocioId], references: [id])
  negocioId      Int
  nombre         String
  email          String?
  telefono       String?
  creadoEn       DateTime       @default(now())
  servicios      Servicio[]
  horarios       Horario[]
  pausas         Pausa[]
  diasBloqueados DiaBloqueado[]
  citas          Cita[]
}

model Servicio {
  id         Int      @id @default(autoincrement())
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
  empleadoId Int
  nombre     String
  duracion   Int
  precio     Float?
  citas      Cita[]
}

model Horario {
  id         Int      @id @default(autoincrement())
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
  empleadoId Int
  diaSemana  String
  horaInicio String
  horaFin    String
}

model Pausa {
  id         Int      @id @default(autoincrement())
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
  empleadoId Int
  diaSemana  String
  horaInicio String
  horaFin    String
}

model DiaBloqueado {
  id         Int      @id @default(autoincrement())
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
  empleadoId Int
  fecha      DateTime
  motivo     String?
}

model Cita {
  id            Int      @id @default(autoincrement())
  negocio       Negocio  @relation(fields: [negocioId], references: [id])
  negocioId     Int
  empleado      Empleado @relation(fields: [empleadoId], references: [id])
  empleadoId    Int
  servicio      Servicio @relation(fields: [servicioId], references: [id])
  servicioId    Int
  nombreCliente String
  emailCliente  String
  fecha         DateTime
  estado        String   @default("pendiente")
  creadoEn      DateTime @default(now())
}
